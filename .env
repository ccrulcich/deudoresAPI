# ─── Base de datos PostgreSQL ─────────────────────────────────────────────
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=deudores_db;Username=postgres;Password=postgres

# ─── Entorno ASP.NET ──────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production

# ─── SQS / LocalStack (opcional — comentar para modo sync) ───────────────
SqsSettings__ServiceUrl=http://localstack:4566
SqsSettings__QueueUrl=http://localstack:4566/000000000000/import-queue
SqsSettings__AccessKey=test
SqsSettings__SecretKey=test
SqsSettings__Region=us-east-1

# ─── Webhook (opcional) ──────────────────────────────────────────────────
Notifications__WebhookUrl=https://webhook.site/687e08c6-ea0d-4187-8f5a-e14754c3db43

# ─── Email SMTP (opcional) ───────────────────────────────────────────────
# Para testing usar Mailtrap: https://mailtrap.io → Email Testing → SMTP Settings
