# Base de datos PostgreSQL
# En Docker, 'Host' debe apuntar al nombre del servicio definido en docker-compose.yml
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=deudores_db;Username=postgres;Password=CHANGE_ME

# Notificaciones (opcional)
# URL del webhook a llamar al finalizar un procesamiento
Notifications__WebhookUrl=

# Configuración de email SMTP (opcional)
# Comentado: requiere servicio SMTP pago para funcionar
#Notifications__Email__SmtpHost=smtp.example.com
#Notifications__Email__SmtpPort=587
#Notifications__Email__Username=user@example.com
#Notifications__Email__Password=secret
#Notifications__Email__From=noreply@example.com
#Notifications__Email__To=admin@example.com

# Procesamiento asíncrono (opcional)
# Con LocalStack (local): ServiceUrl = http://localstack:4566
# Con AWS real: dejar ServiceUrl vac y configurar credenciales reales
SqsSettings__ServiceUrl=http://localstack:4566
SqsSettings__QueueUrl=http://localstack:4566/000000000000/import-queue
SqsSettings__AccessKey=CHANGE_ME
SqsSettings__SecretKey=CHANGE_ME
SqsSettings__Region=us-east-1
